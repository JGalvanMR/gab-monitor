# .env.example — Copiar a .env y configurar antes de levantar con Docker

# ─── Base de datos ─────────────────────────────────────────────────────────────
# Contraseña del usuario sa (o el usuario que uses) de SQL Server GAB_Irapuato
DB_PASSWORD=tu_password_aqui

# ─── Servidor SQL (si cambia el hostname) ─────────────────────────────────────
# DB_SERVER=GABIRA1\SQL2005

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL base del API (si despliegas en un servidor con IP fija, ej: 192.168.1.50)
# VITE_API_URL=http://192.168.1.50:5000/api
